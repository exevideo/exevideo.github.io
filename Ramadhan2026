<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Selamat Hari Raya Idul Fitri 1447 H</title>
<link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@700;900&family=Lateef:wght@400;700&family=Amiri:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --gold: #f0c040;
    --gold2: #e8a020;
    --green: #1a6b3c;
    --green2: #0d4a28;
    --cream: #fdf6e3;
    --glow: rgba(240,192,64,0.55);
  }

  html, body {
    width: 100%; height: 100%;
    background: #060d06;
    overflow: hidden;
    font-family: 'Amiri', serif;
  }

  canvas {
    position: fixed; top: 0; left: 0;
    width: 100%; height: 100%;
    pointer-events: none;
    z-index: 0;
  }

  /* ── Overlay landing screen ── */
  #landing {
    position: fixed; inset: 0;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: url('data:image/png;base64,') center center / cover no-repeat; position: relative;
    transition: opacity 1s ease, visibility 1s ease;
  }
  #landing.hidden { opacity: 0; visibility: hidden; pointer-events: none; }

  /* stars */
  .landing-content-wrap { position: relative; z-index: 2; display: flex; flex-direction: column; align-items: center; width: 100%; padding: 20px 16px; }
  .stars {
    position: absolute; inset: 0;
    background-image:
      radial-gradient(1px 1px at 10% 15%, rgba(255,255,220,.9) 0%, transparent 100%),
      radial-gradient(1.5px 1.5px at 30% 5%, rgba(255,255,200,.7) 0%, transparent 100%),
      radial-gradient(1px 1px at 55% 20%, rgba(255,255,230,.8) 0%, transparent 100%),
      radial-gradient(2px 2px at 75% 8%, rgba(255,255,210,.6) 0%, transparent 100%),
      radial-gradient(1px 1px at 88% 30%, rgba(255,255,220,.9) 0%, transparent 100%),
      radial-gradient(1.5px 1.5px at 20% 40%, rgba(255,255,200,.5) 0%, transparent 100%),
      radial-gradient(1px 1px at 65% 45%, rgba(255,255,220,.7) 0%, transparent 100%),
      radial-gradient(2px 2px at 42% 60%, rgba(255,255,200,.4) 0%, transparent 100%),
      radial-gradient(1px 1px at 90% 55%, rgba(255,255,230,.6) 0%, transparent 100%),
      radial-gradient(1.5px 1.5px at 5%  70%, rgba(255,255,210,.8) 0%, transparent 100%),
      radial-gradient(1px 1px at 35% 80%, rgba(255,255,220,.5) 0%, transparent 100%),
      radial-gradient(2px 2px at 78% 75%, rgba(255,255,200,.7) 0%, transparent 100%),
      radial-gradient(1px 1px at 50% 90%, rgba(255,255,230,.6) 0%, transparent 100%),
      radial-gradient(1.5px 1.5px at 15% 88%, rgba(255,255,210,.4) 0%, transparent 100%),
      radial-gradient(1px 1px at 95% 85%, rgba(255,255,220,.8) 0%, transparent 100%);
    animation: twinkle 3s ease-in-out infinite alternate;
  }
  @keyframes twinkle {
    from { opacity: .6; }
    to   { opacity: 1; }
  }

  /* crescent + star decoration */
  .moon-wrap {
    position: relative;
    margin-bottom: 12px;
    animation: floatMoon 4s ease-in-out infinite;
  }
  @keyframes floatMoon {
    0%,100% { transform: translateY(0); }
    50%      { transform: translateY(-10px); }
  }
  .moon-svg { filter: drop-shadow(0 0 18px var(--gold)); }

  /* lantern line */
  .lanterns {
    display: flex; gap: 32px;
    margin-bottom: 28px;
    animation: sway 3s ease-in-out infinite alternate;
  }
  @keyframes sway {
    from { transform: rotate(-2deg); }
    to   { transform: rotate(2deg); }
  }
  .lantern {
    display: flex; flex-direction: column; align-items: center;
    position: relative;
  }
  .lantern-body {
    width: 22px; height: 34px;
    border-radius: 4px 4px 8px 8px;
    background: linear-gradient(135deg, #d4a800 0%, #f0c040 40%, #d4a800 100%);
    box-shadow: 0 0 14px 4px rgba(240,192,64,.7), inset 0 0 8px rgba(255,255,255,.3);
    position: relative;
    overflow: hidden;
  }
  .lantern-body::after {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(to right, transparent 30%, rgba(255,255,255,.15) 50%, transparent 70%);
  }
  .lantern-string {
    width: 1px; height: 18px;
    background: var(--gold2);
  }
  .lantern-fringe {
    display: flex; gap: 2px; margin-top: 2px;
  }
  .lantern-fringe span {
    width: 1px; height: 8px;
    background: var(--gold2);
    border-radius: 0 0 2px 2px;
  }

  /* Arabic calligraphy / bismillah style header */
  .bismillah {
    font-family: 'Lateef', serif;
    font-size: clamp(1.2rem, 4vw, 2rem);
    color: var(--gold);
    letter-spacing: .05em;
    text-shadow: 0 0 20px var(--glow);
    margin-bottom: 8px;
    direction: rtl;
  }

  /* main greeting */
  .greeting-wrap {
    text-align: center;
    padding: 0 16px;
    margin-bottom: 10px;
  }
  .greeting-main {
    font-family: 'Cinzel Decorative', serif;
    font-size: clamp(1.4rem, 4.5vw, 2.8rem);
    font-weight: 900;
    color: var(--gold);
    text-shadow: 0 0 30px var(--glow), 0 2px 0 var(--gold2);
    line-height: 1.2;
    letter-spacing: .04em;
    background: linear-gradient(180deg, #ffe97a 0%, #f0c040 50%, #c87d00 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: shimmer 3s linear infinite;
    background-size: 200% 100%;
  }
  @keyframes shimmer {
    0%   { background-position: 200% center; }
    100% { background-position: -200% center; }
  }
  .greeting-year {
    font-family: 'Cinzel Decorative', serif;
    font-size: clamp(1rem, 3vw, 1.6rem);
    font-weight: 700;
    color: #e0b040;
    text-shadow: 0 0 12px var(--glow);
    margin-top: 4px;
  }
  .greeting-sub {
    font-family: 'Amiri', serif;
    font-size: clamp(1rem, 2.5vw, 1.35rem);
    color: #c8e8a8;
    text-shadow: 0 0 10px rgba(180,255,100,.4);
    margin-top: 10px;
    font-style: italic;
    letter-spacing: .03em;
  }
  .greeting-community {
    font-family: 'Amiri', serif;
    font-size: clamp(.75rem, 2vw, 1rem);
    color: #8bbf72;
    margin-top: 6px;
    letter-spacing: .08em;
  }

  /* decorative divider */
  .divider {
    display: flex; align-items: center; gap: 12px;
    margin: 14px auto;
    width: min(420px, 90vw);
  }
  .divider-line {
    flex: 1; height: 1px;
    background: linear-gradient(to right, transparent, var(--gold2), transparent);
  }
  .divider-diamond {
    width: 8px; height: 8px;
    background: var(--gold);
    transform: rotate(45deg);
    box-shadow: 0 0 8px var(--glow);
  }

  /* CTA button */
  .btn-wrap { margin-top: 22px; }
  #startBtn {
    font-family: 'Cinzel Decorative', serif;
    font-size: clamp(.85rem, 2.5vw, 1.15rem);
    font-weight: 700;
    letter-spacing: .12em;
    color: #1a2a0a;
    background: linear-gradient(135deg, #ffe97a 0%, #f0c040 40%, #c87d00 70%, #f0c040 100%);
    background-size: 200% 200%;
    border: none;
    border-radius: 50px;
    padding: 14px 42px;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    box-shadow: 0 0 24px var(--glow), 0 4px 16px rgba(0,0,0,.5);
    transition: transform .15s, box-shadow .15s;
    animation: btnPulse 2.5s ease-in-out infinite, btnBg 4s linear infinite;
  }
  @keyframes btnPulse {
    0%,100% { box-shadow: 0 0 24px var(--glow), 0 4px 16px rgba(0,0,0,.5); }
    50%      { box-shadow: 0 0 42px rgba(240,192,64,.9), 0 4px 24px rgba(0,0,0,.6); }
  }
  @keyframes btnBg {
    0%   { background-position: 0% 50%; }
    50%  { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }
  #startBtn:hover  { transform: scale(1.06); }
  #startBtn:active { transform: scale(.97); }
  #startBtn::before {
    content: '';
    position: absolute; top: -50%; left: -60%;
    width: 50%; height: 200%;
    background: rgba(255,255,255,.25);
    transform: skewX(-20deg);
    animation: btnShine 3s linear infinite;
  }
  @keyframes btnShine {
    0%   { left: -60%; }
    100% { left: 160%; }
  }

  /* ── Celebration UI (shown after click) ── */
  #celebration {
    position: fixed; inset: 0;
    z-index: 5;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    pointer-events: none;
    opacity: 0; visibility: hidden;
    transition: opacity 1.2s ease .3s;
  }
  #celebration.visible { opacity: 1; visibility: visible; }

  .cel-card {
    background: linear-gradient(160deg,
      rgba(13,74,40,.85) 0%,
      rgba(6,20,6,.9) 50%,
      rgba(13,74,40,.85) 100%);
    border: 1px solid rgba(240,192,64,.4);
    border-radius: 20px;
    padding: clamp(24px,5vw,48px) clamp(28px,6vw,64px);
    text-align: center;
    backdrop-filter: blur(6px);
    box-shadow:
      0 0 60px rgba(240,192,64,.15),
      0 0 0 1px rgba(240,192,64,.08),
      inset 0 1px 0 rgba(255,255,255,.06);
    max-width: min(600px, 92vw);
    animation: cardIn 1s cubic-bezier(.22,1,.36,1) both;
    animation-delay: .5s;
    position: relative;
    overflow: hidden;
  }
  @keyframes cardIn {
    from { transform: scale(.7) translateY(40px); opacity: 0; }
    to   { transform: scale(1) translateY(0);     opacity: 1; }
  }
  /* corner ornaments */
  .cel-card::before, .cel-card::after {
    content: '✦';
    position: absolute;
    font-size: 1.6rem;
    color: var(--gold2);
    opacity: .5;
  }
  .cel-card::before { top: 10px; left: 14px; }
  .cel-card::after  { bottom: 10px; right: 14px; }

  .cel-arabic {
    font-family: 'Lateef', serif;
    font-size: clamp(1.8rem, 6vw, 3.2rem);
    color: var(--gold);
    text-shadow: 0 0 30px var(--glow);
    direction: rtl;
    line-height: 1.3;
    margin-bottom: 6px;
  }
  .cel-main {
    font-family: 'Cinzel Decorative', serif;
    font-size: clamp(1.1rem, 3.5vw, 2rem);
    font-weight: 900;
    background: linear-gradient(180deg, #fff8c0 0%, #f0c040 60%, #c87d00 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1.25;
    margin-bottom: 4px;
  }
  .cel-year {
    font-family: 'Cinzel Decorative', serif;
    font-size: clamp(.85rem, 2.5vw, 1.3rem);
    color: #d4a030;
    margin-bottom: 16px;
  }
  .cel-taqabbal {
    font-family: 'Amiri', serif;
    font-size: clamp(1rem, 2.8vw, 1.5rem);
    color: #b8e898;
    font-style: italic;
    text-shadow: 0 0 12px rgba(140,220,80,.3);
    margin-bottom: 8px;
  }
  .cel-community {
    font-family: 'Amiri', serif;
    font-size: clamp(.75rem, 2vw, 1rem);
    color: #6a9f52;
    letter-spacing: .1em;
  }
  .cel-divider {
    display: flex; align-items: center; gap: 10px;
    margin: 12px auto;
    width: 80%;
  }
  .cel-divider-line {
    flex: 1; height: 1px;
    background: linear-gradient(to right, transparent, rgba(240,192,64,.5), transparent);
  }
  .cel-divider-star { color: var(--gold); font-size: .9rem; }

  /* particle burst CSS rings */
  .burst { position: absolute; inset: 0; pointer-events: none; }
</style>
</head>
<body>

<canvas id="canvas"></canvas>

<!-- LANDING SCREEN -->
<div id="landing">
  <div class="stars"></div>
  <div style="position:absolute;inset:0;background:rgba(0,0,0,0.52);z-index:0;border-radius:inherit;"></div>

  <!-- Moon SVG -->
  <div class="landing-content-wrap">
  <div class="moon-wrap">
    <svg class="moon-svg" width="90" height="90" viewBox="0 0 90 90">
      <defs>
        <radialGradient id="moonG" cx="40%" cy="40%">
          <stop offset="0%" stop-color="#fff8a0"/>
          <stop offset="60%" stop-color="#f0c040"/>
          <stop offset="100%" stop-color="#c87d00"/>
        </radialGradient>
      </defs>
      <!-- crescent -->
      <path d="M55 10 A35 35 0 1 0 55 80 A25 25 0 1 1 55 10 Z" fill="url(#moonG)"/>
      <!-- star -->
      <polygon points="72,30 74,38 82,38 76,43 78,51 72,46 66,51 68,43 62,38 70,38"
               fill="#f0c040" opacity=".9"/>
    </svg>
  </div>

  <!-- Lanterns -->
  <div class="lanterns">
    <div class="lantern">
      <div class="lantern-string"></div>
      <div class="lantern-body"></div>
      <div class="lantern-fringe"><span></span><span></span><span></span></div>
    </div>
    <div class="lantern">
      <div class="lantern-string" style="height:28px"></div>
      <div class="lantern-body" style="width:28px;height:44px"></div>
      <div class="lantern-fringe"><span></span><span></span><span></span><span></span></div>
    </div>
    <div class="lantern">
      <div class="lantern-string"></div>
      <div class="lantern-body"></div>
      <div class="lantern-fringe"><span></span><span></span><span></span></div>
    </div>
  </div>

  <p class="bismillah">بِسْمِ اللَّهِ الرَّحْمَنِ الرَّحِيمِ</p>

  <div class="divider">
    <div class="divider-line"></div>
    <div class="divider-diamond"></div>
    <div class="divider-line"></div>
  </div>

  <div class="greeting-wrap">
    <div class="greeting-main">Selamat Hari Raya<br>Idul Fitri</div>
    <div class="greeting-year">1447 Hijriah</div>
    <div class="greeting-sub">Taqabbalallahu Minna Wa Minkum</div>
    <div class="greeting-community">— @community miracle roleplay —</div>
  </div>

  <div class="divider">
    <div class="divider-line"></div>
    <div class="divider-diamond"></div>
    <div class="divider-line"></div>
  </div>

  <div class="btn-wrap">
    <button id="startBtn" onclick="startCelebration()">✨ Click Here! ✨</button>
  </div>
  </div><!-- end landing-content-wrap -->
</div>

<!-- CELEBRATION SCREEN -->
<div id="celebration">
  <div class="cel-card">
    <p class="cel-arabic">عِيدُ مُبَارَك</p>
    <div class="cel-main">Selamat Hari Raya<br>Idul Fitri</div>
    <div class="cel-year">1447 Hijriah</div>
    <div class="cel-divider">
      <div class="cel-divider-line"></div>
      <span class="cel-divider-star">✦</span>
      <div class="cel-divider-line"></div>
    </div>
    <div class="cel-taqabbal">Taqabbalallahu Minna Wa Minkum</div>
    <div class="cel-taqabbal" style="font-size:85%;color:#8fc870;margin-top:4px">Minal Aidin Wal Faizin — Mohon Maaf Lahir & Batin</div>
    <div class="cel-divider">
      <div class="cel-divider-line"></div>
      <span class="cel-divider-star">✦</span>
      <div class="cel-divider-line"></div>
    </div>
    <div class="cel-community">@community miracle roleplay</div>
  </div>
</div>

<script>
(function () {
  'use strict';

  var canvas = document.getElementById('canvas'),
      ctx    = canvas.getContext('2d'),
      W      = canvas.width  = window.innerWidth,
      H      = canvas.height = window.innerHeight,
      maxP   = 700,
      minP   = 900,
      fireworks = [],
      running = false;

  window.addEventListener('resize', function () {
    W = canvas.width  = window.innerWidth;
    H = canvas.height = window.innerHeight;
  });

  function tick() {
    var nf = [];
    ctx.fillStyle = 'rgba(0,0,0,0.18)';
    ctx.fillRect(0, 0, W, H);
    fireworks.forEach(function (fw) { fw.draw(); if (!fw.done) nf.push(fw); });
    fireworks = nf;
    requestAnimationFrame(tick);
  }

  function Vector(x, y) { this.x = x; this.y = y; }
  Vector.prototype = {
    constructor: Vector,
    add:  function (v) { this.x += v.x; this.y += v.y; },
    diff: function (v) { var t = this.copy(); return Math.sqrt((t.x -= v.x)*t.x + (t.y -= v.y)*t.y); },
    copy: function ()  { return new Vector(this.x, this.y); }
  };

  var colors = [
    ['rgba(255,220,60,',  'rgba(255,255,150,'],
    ['rgba(0,220,120,',   'rgba(120,255,200,'],
    ['rgba(255,80,80,',   'rgba(255,200,80,'],
    ['rgba(180,60,255,',  'rgba(255,130,220,'],
    ['rgba(60,160,255,',  'rgba(180,240,255,'],
    ['rgba(255,140,0,',   'rgba(255,220,80,']
  ];

  function Firework(start, target) {
    this.start  = start;
    this.pos    = start.copy();
    this.target = target;
    this.spread = Math.round(Math.random() * (maxP - minP)) + minP;
    this.distance = target.diff(start);
    this.speed  = Math.random() * 5 + 14;
    this.angle  = Math.atan2(target.y - start.y, target.x - start.x);
    this.velocity = new Vector(Math.cos(this.angle) * this.speed, Math.sin(this.angle) * this.speed);
    this.prevPos = [];
    var cs = colors[Math.floor(Math.random() * colors.length)];
    this.particles = [];
    for (var i = 0; i < this.spread; i++) this.particles.push(new Particle(target.copy(), cs));
  }
  Firework.prototype = {
    constructor: Firework,
    draw: function () {
      var last = this.prevPos[this.prevPos.length - 1] || this.pos;
      ctx.beginPath(); ctx.moveTo(last.x, last.y); ctx.lineTo(this.pos.x, this.pos.y);
      ctx.strokeStyle = 'rgba(255,255,255,.8)'; ctx.lineWidth = 2; ctx.stroke();
      this.update();
    },
    update: function () {
      if (this.start.diff(this.pos) >= this.distance) {
        var np = [];
        this.particles.forEach(function (p) { p.draw(); if (!p.done) np.push(p); });
        this.particles = np; this.prevPos = [];
        if (!np.length) this.done = true;
      } else {
        this.prevPos.push(this.pos.copy());
        if (this.prevPos.length > 8) this.prevPos.shift();
        this.pos.add(this.velocity);
      }
    }
  };

  function Particle(pos, cs) {
    this.pos   = pos;
    this.ease  = 0.18;
    this.speed = Math.random() * 7 + 2;
    this.grav  = Math.random() * 2 + 0.1;
    this.alpha = .85;
    this.angle = Math.random() * Math.PI * 2;
    this.color = cs[Math.floor(Math.random() * cs.length)];
    this.prevPos = [];
  }
  Particle.prototype = {
    constructor: Particle,
    draw: function () {
      var last = this.prevPos[this.prevPos.length - 1] || this.pos;
      ctx.beginPath(); ctx.moveTo(last.x, last.y); ctx.lineTo(this.pos.x, this.pos.y);
      ctx.strokeStyle = this.color + this.alpha + ')'; ctx.lineWidth = 1.5; ctx.stroke();
      this.update();
    },
    update: function () {
      if (this.alpha <= 0) { this.done = true; return; }
      this.prevPos.push(this.pos.copy());
      if (this.prevPos.length > 10) this.prevPos.shift();
      if (this.speed > 1) this.speed -= this.ease;
      this.alpha -= 0.012; this.grav += 0.012;
      this.pos.add({ x: Math.cos(this.angle) * this.speed, y: Math.sin(this.angle) * this.speed + this.grav });
    }
  };

  function addFirework(target) {
    var sx = W / 2 + (Math.random() - .5) * W * .3;
    target = target || new Vector(Math.random() * W, Math.random() * (H - 250));
    fireworks.push(new Firework(new Vector(sx, H), target));
  }

  canvas.addEventListener('click', function (e) {
    if (running) addFirework(new Vector(e.clientX, e.clientY));
  });

  function randomFirework() {
    if (running) addFirework();
    setTimeout(randomFirework, Math.random() * 600 + 200);
  }

  tick();

  window.startCelebration = function () {
    document.getElementById('landing').classList.add('hidden');
    document.getElementById('celebration').classList.add('visible');
    running = true;
    // burst of fireworks on start
    for (var i = 0; i < 8; i++) {
      (function(delay){ setTimeout(function(){ addFirework(); }, delay); })(i * 180);
    }
    randomFirework();
  };
})();
</script>
</body>
</html>
